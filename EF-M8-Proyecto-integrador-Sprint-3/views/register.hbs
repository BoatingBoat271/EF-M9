{{> header}}

<div class="auth-wrapper d-flex align-items-center py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">

        <div class="text-center mb-4">
          <a href="/" class="text-decoration-none">
            <span class="fw-bold fs-4 text-primary">KanbanPro</span>
          </a>
        </div>

        <div class="card auth-card shadow-lg border-0 rounded-4">
          <div class="card-body p-5">

            <div class="text-center mb-4">
              <h2 class="fw-bold">Crear cuenta</h2>
              <p class="text-muted">Comienza a gestionar tus tareas hoy</p>
            </div>

            <form id="registerForm">
              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Correo electronico</label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  name="email"
                  placeholder="correo@ejemplo.com"
                  required
                />
              </div>

              <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Contrasena</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="password"
                  name="password"
                  placeholder="Minimo 8 caracteres"
                  required
                />
              </div>

              <div class="mb-4">
                <label for="confirm" class="form-label fw-semibold">Confirmar contrasena</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="confirm"
                  name="confirm"
                  placeholder="Repite tu contrasena"
                  required
                />
              </div>

              <button
                type="submit"
                class="btn btn-primary btn-lg w-100 rounded-pill"
              >
                Registrarse
              </button>
            </form>

            <p id="registerError" class="text-danger small mt-3 mb-0"></p>
            <p id="registerSuccess" class="text-success small mt-2 mb-0"></p>

            <div class="text-center mt-4">
              <p class="text-muted mb-0">
                Ya tienes cuenta?
                <a href="/login" class="text-primary fw-semibold text-decoration-none">
                  Inicia sesion
                </a>
              </p>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{{> footer}}

<script>
  const registerForm = document.getElementById('registerForm');
  const registerError = document.getElementById('registerError');
  const registerSuccess = document.getElementById('registerSuccess');

  registerForm.addEventListener('submit', async function (event) {
    event.preventDefault();
    registerError.textContent = '';
    registerSuccess.textContent = '';

    const email = document.getElementById('email').value.trim();
    const password = document.getElementById('password').value;
    const confirm = document.getElementById('confirm').value;

    if (password !== confirm) {
      registerError.textContent = 'Las contrasenas no coinciden';
      return;
    }

    try {
      const response = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });

      const data = await response.json();

      if (!response.ok) {
        registerError.textContent = data.message || 'No se pudo registrar';
        return;
      }

      registerSuccess.textContent = 'Registro exitoso. Redirigiendo al login...';
      setTimeout(function () {
        window.location.href = '/login';
      }, 1000);
    } catch (error) {
      registerError.textContent = 'Error de red. Intenta nuevamente.';
    }
  });
</script>
