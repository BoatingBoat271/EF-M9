<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KanbanPro</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
  />
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold fs-4" href="/">
      KanbanPro
    </a>
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto gap-1">
        <li class="nav-item">
          <a class="nav-link px-3" href="/">Inicio</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3" href="/register">Registro</a>
        </li>
        <li class="nav-item">
          <a class="nav-link px-3" href="/login">Login</a>
        </li>
        <li class="nav-item">
          <a id="dashboardLink" class="nav-link btn btn-primary text-white px-4 ms-2 rounded-pill" href="/dashboard">
            Dashboard
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  (function () {
    var token = localStorage.getItem('kanbanpro_token');
    var dashboardLink = document.getElementById('dashboardLink');

    if (token && dashboardLink) {
      dashboardLink.href = '/dashboard?token=' + encodeURIComponent(token);
    }
  })();
</script>
