{{> header}}

<div class="auth-wrapper d-flex align-items-center py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">

        <div class="text-center mb-4">
          <a href="/" class="text-decoration-none">
            <span class="fw-bold fs-4 text-primary">KanbanPro</span>
          </a>
        </div>

        <div class="card auth-card shadow-lg border-0 rounded-4">
          <div class="card-body p-5">

            <div class="text-center mb-4">
              <div class="auth-avatar mb-3">🔑</div>
              <h2 class="fw-bold">Bienvenido de vuelta</h2>
              <p class="text-muted">Ingresa a tu cuenta de KanbanPro</p>
            </div>

            <form>
              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Correo electrónico</label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  placeholder="correo@ejemplo.com"
                />
              </div>

              <div class="mb-2">
                <label for="password" class="form-label fw-semibold">Contraseña</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="password"
                  placeholder="Tu contraseña"
                />
              </div>

              <div class="d-flex justify-content-end mb-4">
                <a href="#" class="text-muted small text-decoration-none">
                  ¿Olvidaste tu contraseña?
                </a>
              </div>

              <button
                type="button"
                class="btn btn-primary btn-lg w-100 rounded-pill"
                onclick="window.location.href='/dashboard'"
              >
                Iniciar sesión
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted mb-0">
                ¿No tienes cuenta?
                <a href="/register" class="text-primary fw-semibold text-decoration-none">
                  Regístrate gratis
                </a>
              </p>
            </div>

          </div>
        </div>



      </div>
    </div>
  </div>
</div>

{{> footer}}
