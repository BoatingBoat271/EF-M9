{{> header}}

<div class="auth-wrapper d-flex align-items-center py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">

        <div class="text-center mb-4">
          <a href="/" class="text-decoration-none">
            <span class="fw-bold fs-4 text-primary">KanbanPro</span>
          </a>
        </div>

        <div class="card auth-card shadow-lg border-0 rounded-4">
          <div class="card-body p-5">

            <div class="text-center mb-4">
              <div class="auth-avatar mb-3">👤</div>
              <h2 class="fw-bold">Crear cuenta</h2>
              <p class="text-muted">Comienza a gestionar tus tareas hoy</p>
            </div>

            <form>
              <div class="mb-3">
                <label for="nombre" class="form-label fw-semibold">Nombre completo</label>
                <input
                  type="text"
                  class="form-control form-control-lg"
                  id="nombre"
                  placeholder="Tu nombre completo"
                />
              </div>

              <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Correo electrónico</label>
                <input
                  type="email"
                  class="form-control form-control-lg"
                  id="email"
                  placeholder="correo@ejemplo.com"
                />
              </div>

              <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Contraseña</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="password"
                  placeholder="Mínimo 8 caracteres"
                />
              </div>

              <div class="mb-4">
                <label for="confirm" class="form-label fw-semibold">Confirmar contraseña</label>
                <input
                  type="password"
                  class="form-control form-control-lg"
                  id="confirm"
                  placeholder="Repite tu contraseña"
                />
              </div>

              <button
                type="button"
                class="btn btn-primary btn-lg w-100 rounded-pill"
                onclick="window.location.href='/dashboard'"
              >
                Registrarse e ir al Dashboard
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted mb-0">
                ¿Ya tienes cuenta?
                <a href="/login" class="text-primary fw-semibold text-decoration-none">
                  Inicia sesión
                </a>
              </p>
            </div>

          </div>
        </div>



      </div>
    </div>
  </div>
</div>

{{> footer}}
