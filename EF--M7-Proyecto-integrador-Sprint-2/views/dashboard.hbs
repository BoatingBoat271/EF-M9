{{> header}}

<div class="container-fluid py-4">

  <!-- Encabezado del dashboard -->
  <div class="d-flex justify-content-between align-items-center mb-4 px-2">
    <div>
      <h2 class="fw-bold mb-0">Tablero de tareas</h2>
      <p class="text-muted small mb-0">Organiza y gestiona tus tarjetas por estado</p>
    </div>
    <button
      class="btn btn-primary px-4 rounded-pill"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#formNuevaTarjeta"
      aria-expanded="false"
      aria-controls="formNuevaTarjeta"
    >
      + Nueva tarjeta
    </button>
  </div>

  <!-- Formulario para crear nueva tarjeta (colapsable) -->
  <div class="collapse mb-4 px-2" id="formNuevaTarjeta">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-4">Crear nueva tarjeta</h5>

        <form method="POST" action="/nueva-tarjeta">
          <div class="row g-3">

            <!-- Título (obligatorio) -->
            <div class="col-md-6">
              <label class="form-label fw-semibold">
                Título <span class="text-danger">*</span>
              </label>
              <input
                type="text"
                name="titulo"
                class="form-control"
                placeholder="Nombre de la tarea"
                required
              />
            </div>

            <!-- Lista/Columna destino (select dinámico con datos del servidor) -->
            <div class="col-md-6">
              <label class="form-label fw-semibold">Lista (columna destino)</label>
              <select name="lista" class="form-select">
                {{#each tableros}}
                  <option value="{{nombre}}">{{nombre}}</option>
                {{/each}}
              </select>
            </div>

            <!-- Descripción -->
            <div class="col-12">
              <label class="form-label fw-semibold">Descripción</label>
              <textarea
                name="descripcion"
                class="form-control"
                rows="2"
                placeholder="Detalla el alcance de esta tarea..."
              ></textarea>
            </div>

            <!-- Prioridad -->
            <div class="col-md-4">
              <label class="form-label fw-semibold">Prioridad</label>
              <select name="prioridad" class="form-select">
                <option value="Alta">Alta</option>
                <option value="Media" selected>Media</option>
                <option value="Baja">Baja</option>
              </select>
            </div>

            <!-- Tag -->
            <div class="col-md-4">
              <label class="form-label fw-semibold">Tag</label>
              <input
                type="text"
                name="tag"
                class="form-control"
                placeholder="Ej: Frontend, Backend, QA..."
              />
            </div>

            <!-- Autor -->
            <div class="col-md-4">
              <label class="form-label fw-semibold">Autor</label>
              <input
                type="text"
                name="autor"
                class="form-control"
                placeholder="Tu nombre"
              />
            </div>

            <!-- Responsable -->
            <div class="col-md-4">
              <label class="form-label fw-semibold">Responsable</label>
              <input
                type="text"
                name="responsable"
                class="form-control"
                placeholder="Responsable de la tarea"
              />
            </div>

            <!-- Botones -->
            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
              <button
                type="button"
                class="btn btn-outline-secondary rounded-pill px-4"
                data-bs-toggle="collapse"
                data-bs-target="#formNuevaTarjeta"
              >
                Cancelar
              </button>
              <button type="submit" class="btn btn-primary rounded-pill px-5">
                Guardar tarjeta
              </button>
            </div>

          </div>
        </form>

      </div>
    </div>
  </div>

  <!-- Tablero Kanban: columnas renderizadas dinámicamente -->
  <div class="kanban-board px-2">

    {{#each tableros}}
    <div class="kanban-column">

      <!-- Encabezado de columna -->
      <div class="kanban-column-header">
        <span class="column-title">{{nombre}}</span>
        <span class="badge bg-secondary column-count">{{tarjetas.length}}</span>
      </div>

      <!-- Tarjetas de la columna -->
      <div class="kanban-cards">

        {{#each tarjetas}}
        <div class="kanban-card">

          <!-- Fila superior: tag + prioridad -->
          <div class="card-top">
            {{#if tag}}
              <span class="card-tag">{{tag}}</span>
            {{else}}
              <span class="card-tag card-tag-empty">General</span>
            {{/if}}
            <span class="card-priority priority-{{prioridad}}">{{prioridad}}</span>
          </div>

          <!-- Título -->
          <h6 class="card-title-text">{{titulo}}</h6>

          <!-- Descripción (solo si existe) -->
          {{#if descripcion}}
            <p class="card-desc">{{descripcion}}</p>
          {{/if}}

          <!-- Pie: autor y fecha -->
          <div class="card-footer-info">
            <span class="card-author">&#128100; {{autor}}</span>
            <span class="card-date">&#128197; {{fecha_creacion}}</span>
          </div>

        </div>
        {{else}}
        <!-- Mensaje cuando la columna está vacía -->
        <div class="kanban-empty">
          <p>Sin tarjetas aún</p>
          <small>Crea una nueva tarjeta y asígnala aquí</small>
        </div>
        {{/each}}

      </div>
    </div>
    {{/each}}

  </div>
</div>

{{> footer}}
